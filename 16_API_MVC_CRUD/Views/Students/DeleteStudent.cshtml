@model Student

<div class="container">
    <div class="card shadow-lg col-md-6 mx-auto p-4 myCard">
        <h2 class="text-center text-danger">Delete Student</h2>
        <form asp-action="DeleteStudent" method="post" id="deleteForm">
            <input type="hidden" asp-for="Id" />

            <div class="mt-3">
                <p>Id : @Model.Id</p>
                <p>Name : @Model.Name</p>
                <p>City : @Model.City</p>
            </div>
            <div class="d-flex gap-3 mb-3 justify-content-center">
                <button type="button"
                    data-bs-toggle="modal"
                    data-bs-target="#DeleteModal"
                    class="btn btn-danger">Delete</button>
                <a asp-action="ListStudent" class="btn btn-secondary">Back</a>
            </div>
        </form>
        <div class="modal" id="DeleteModal">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Delete Confirmation</h5>
                        <button type="button"
                            class="btn-close"
                            data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>Are you sure want to delete?</p>
                        <strong>@Model.Name</strong>
                        <p>This action cannot be undone.</p>
                    </div>

                    <div class="modal-footer">
                        <button type="button"
                            data-bs-dismiss="modal"
                            class="btn btn-secondary">Cancel</button>
                         <button type="submit"
                             class="btn btn-danger"
                             form="deleteForm">Yes,Delete</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
